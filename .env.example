# MartinStrategy 环境变量配置示例
# 复制为 .env 并根据需要修改

# =====================================
# 交易所配置 (必填)
# =====================================

# 交易对
MARTIN_EXCHANGE_SYMBOL=HYPEUSDC

# Lighter 私钥 (hex 格式) ⚠️ 必须配置
# 可以通过 Lighter 网站生成
MARTIN_EXCHANGE_PRIVATE_KEY=your_private_key_here

# 链 ID (1=主网)
MARTIN_EXCHANGE_CHAIN_ID=1

# API 地址
MARTIN_EXCHANGE_API_URL=https://mainnet.zklighter.elliot.ai

# 账户索引
MARTIN_EXCHANGE_ACCOUNT_INDEX=1

# API 密钥索引
MARTIN_EXCHANGE_API_KEY_INDEX=0

# 市场索引
MARTIN_EXCHANGE_MARKET_INDEX=0

# =====================================
# 策略配置
# =====================================

# 最大加仓层数
MARTIN_STRATEGY_MAX_SAFETY_ORDERS=9

# 底仓数量
MARTIN_STRATEGY_BASE_QTY=0.5

# ATR 周期
MARTIN_STRATEGY_ATR_PERIOD=14

# =====================================
# 存储配置
# =====================================

# SQLite 数据库路径
MARTIN_STORAGE_SQLITE_PATH=bot.db

# Redis 地址 (可选)
MARTIN_STORAGE_REDIS_ADDR=localhost:6379

# Redis 密码 (可选)
MARTIN_STORAGE_REDIS_PASS=

# Redis 数据库 (可选)
MARTIN_STORAGE_REDIS_DB=0

# =====================================
# 日志配置
# =====================================

# 日志级别: trace, debug, info, warn, error
MARTIN_LOG_LEVEL=info

# Rust 日志格式 (可选)
RUST_LOG=martin_strategy=info

# 显示回溯 (调试用)
# RUST_BACKTRACE=1
